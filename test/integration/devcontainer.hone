#! shell: /bin/bash
#! timeout: 60s

# Grove devcontainer integration tests.
#
# These tests verify the container-routing wiring in isolation — they do NOT
# spin up a real devcontainer (CI runners can't reliably provide one). The
# real devcontainer CLI is substituted via GROVE_DEVCONTAINER_COMMAND with an
# echo-like shim where helpful, OR the test ensures grove falls back to host
# behavior when devcontainer is unavailable.
#
# Cross-cutting: every test that needs an initialized grove project uses a
# disposable repo under /tmp.

TEST "grove devcontainer --help surfaces the new subcommands"

RUN grove devcontainer --help
ASSERT exit_code == 0
ASSERT stdout contains "up"
ASSERT stdout contains "down"
ASSERT stdout contains "status"
ASSERT stdout contains "exec"
ASSERT stdout contains "rebuild"
ASSERT stdout contains "logs"

TEST "grove devcontainer up outside a grove repo errors cleanly"

ENV TEST_DIR=/tmp/grove-devcontainer-no-repo
RUN setup: rm -rf $TEST_DIR && mkdir -p $TEST_DIR
RUN no-repo: cd $TEST_DIR && grove devcontainer up
ASSERT no-repo.exit_code != 0
ASSERT no-repo.stderr contains "Not in a grove repository"
RUN cleanup: rm -rf $TEST_DIR

TEST "grove devcontainer status reports DOWN when not initialized"

ENV TEST_DIR=/tmp/grove-devcontainer-status-init
RUN setup: rm -rf $TEST_DIR && mkdir -p $TEST_DIR && cd $TEST_DIR && git init -q && git -c user.email=t@t -c user.name=t commit --allow-empty -q -m init && grove init --no-agent
# Use the stub override so we don't try to talk to a real devcontainer.
ENV GROVE_DEVCONTAINER_COMMAND=/usr/bin/false
RUN st: cd $TEST_DIR && grove devcontainer status
ASSERT st.exit_code == 0
ASSERT st.stdout contains "DOWN"
RUN cleanup: rm -rf $TEST_DIR

TEST "grove devcontainer up reports the stub failure cleanly"

ENV TEST_DIR=/tmp/grove-devcontainer-up-fail
RUN setup: rm -rf $TEST_DIR && mkdir -p $TEST_DIR && cd $TEST_DIR && git init -q && git -c user.email=t@t -c user.name=t commit --allow-empty -q -m init && grove init --no-agent
ENV GROVE_DEVCONTAINER_COMMAND=/usr/bin/false
RUN up-fail: cd $TEST_DIR && grove devcontainer up
ASSERT up-fail.exit_code != 0
ASSERT up-fail.stderr contains "devcontainer up failed"
RUN cleanup: rm -rf $TEST_DIR

TEST "grove spawn falls back to host tmux when devcontainer is disabled"

ENV TEST_DIR=/tmp/grove-spawn-no-container
RUN setup: rm -rf $TEST_DIR && mkdir -p $TEST_DIR && cd $TEST_DIR && git init -q && git -c user.email=t@t -c user.name=t commit --allow-empty -q -m init && grove init --no-agent
# Flip [devcontainer] enabled = false in the config.
RUN disable: cd $TEST_DIR && sed -i 's/^enabled = true$/enabled = false/' .grove/config.toml
# Use a stub command so we don't actually try to run claude.
ENV GROVE_AGENT_COMMAND=sleep 1
RUN spawn-host: cd $TEST_DIR && grove spawn smoke-host
ASSERT spawn-host.exit_code == 0
ASSERT spawn-host.stdout contains "[host]"
ASSERT spawn-host.stdout contains "tmux attach -t grove-smoke-host"
# Clean up the tmux session if it actually launched.
RUN tmux-cleanup: tmux kill-session -t grove-smoke-host 2>/dev/null || true
RUN cleanup: rm -rf $TEST_DIR

TEST "grove spawn warns + falls back when devcontainer CLI is missing"

ENV TEST_DIR=/tmp/grove-spawn-missing-cli
RUN setup: rm -rf $TEST_DIR && mkdir -p $TEST_DIR && cd $TEST_DIR && git init -q && git -c user.email=t@t -c user.name=t commit --allow-empty -q -m init && grove init --no-agent
# Point GROVE_DEVCONTAINER_COMMAND at a binary that doesn't exist — emulates
# "devcontainer CLI not installed".
ENV GROVE_DEVCONTAINER_COMMAND=/nonexistent/devcontainer-binary
ENV GROVE_AGENT_COMMAND=sleep 1
RUN spawn-missing: cd $TEST_DIR && grove spawn smoke-missing
ASSERT spawn-missing.exit_code == 0
# Stderr quotes the command in backticks: "Warning: `devcontainer up` failed: …"
ASSERT spawn-missing.stderr contains "devcontainer up"
ASSERT spawn-missing.stderr contains "falling back to host tmux"
ASSERT spawn-missing.stdout contains "[host]"
# Clean up.
RUN tmux-cleanup: tmux kill-session -t grove-smoke-missing 2>/dev/null || true
RUN cleanup: rm -rf $TEST_DIR
