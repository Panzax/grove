#! shell: /bin/bash
#! timeout: 60s

# Grove agentic-flow Integration Tests
# Verifies the new fork-specific surface from outside the test binary.
# These tests do NOT require Claude Code, tmux, or a devcontainer — they
# exercise the deterministic Phase 1 scaffold + the commands that should
# fail-clean in absence of project context.

TEST "grove --help lists the new agentic commands"

RUN grove --help
ASSERT exit_code == 0
ASSERT stdout contains "spawn"
ASSERT stdout contains "agents"
ASSERT stdout contains "loop"
ASSERT stdout contains "msg"
ASSERT stdout contains "integrate"

TEST "grove spawn --help shows --task and --branch"

RUN grove spawn --help
ASSERT exit_code == 0
ASSERT stdout contains "--task"
ASSERT stdout contains "--branch"

TEST "grove init --help advertises --no-agent and --reconfigure"

RUN grove init --help
ASSERT exit_code == 0
ASSERT stdout contains "no-agent"
ASSERT stdout contains "no-devcontainer"
ASSERT stdout contains "reconfigure"

TEST "grove agents list outside a grove repo errors cleanly"

ENV TEST_DIR=/tmp/grove-agents-no-repo
RUN setup: rm -rf $TEST_DIR && mkdir -p $TEST_DIR
RUN cd: $TEST_DIR
RUN grove agents list
ASSERT exit_code == 1
ASSERT stderr contains "Error"

TEST "grove loop outside a grove repo errors cleanly"

ENV TEST_DIR=/tmp/grove-loop-no-repo
RUN setup: rm -rf $TEST_DIR && mkdir -p $TEST_DIR
RUN cd: $TEST_DIR
RUN grove loop
ASSERT exit_code == 1
ASSERT stderr contains "Error"

TEST "grove msg outside a grove repo errors cleanly"

ENV TEST_DIR=/tmp/grove-msg-no-repo
RUN setup: rm -rf $TEST_DIR && mkdir -p $TEST_DIR
RUN cd: $TEST_DIR
RUN grove msg broadcast "hello"
ASSERT exit_code == 1
ASSERT stderr contains "Error"

TEST "grove integrate outside a grove repo errors cleanly"

ENV TEST_DIR=/tmp/grove-integrate-no-repo
RUN setup: rm -rf $TEST_DIR && mkdir -p $TEST_DIR
RUN cd: $TEST_DIR
RUN grove integrate
ASSERT exit_code == 1
ASSERT stderr contains "Error"
